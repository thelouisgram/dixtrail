generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  SALES_REP
}

enum LocationStatus {
  ASSIGNED
  REACHED_OUT
  FOLLOW_UP
  INTERESTED
  SIGNED
  INSTALLED
  DECLINED
}

enum ContactMode {
  EMAIL
  PHONE
  IN_PERSON
}

enum ActivityType {
  LOCATION_CREATED
  LOCATION_UPDATED
  LOCATION_STATUS_CHANGED
  LOCATION_ASSIGNED
  LOCATION_DELETED
}

enum NotificationType {
  LOCATION_ASSIGNED
  CITY_ASSIGNED
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  email     String   @unique
  password  String?
  role      Role     @default(SALES_REP)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedLocations Location[]     @relation("AssignedRep")
  createdLocations  Location[]     @relation("CreatedBy")
  assignedCities    UserCity[]
  activities        Activity[]
  notifications     Notification[]
}

model Country {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  states    State[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  locations Location[]
}

model State {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  countryId String   @db.ObjectId
  country   Country  @relation(fields: [countryId], references: [id])
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  locations Location[]

  @@unique([name, countryId])
}

model City {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  stateId   String   @db.ObjectId
  state     State    @relation(fields: [stateId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  locations Location[]
  userAssignments UserCity[]
  notifications   Notification[]

  @@unique([name, stateId])
}

model UserCity {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  cityId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([userId, cityId])
}

model Location {
  id                  String         @id @default(auto()) @map("_id") @db.ObjectId
  eventName           String
  countryId           String         @db.ObjectId
  country             Country        @relation(fields: [countryId], references: [id])
  stateId             String         @db.ObjectId
  state               State          @relation(fields: [stateId], references: [id])
  cityId              String?        @db.ObjectId
  city                City?          @relation(fields: [cityId], references: [id])
  address             String?
  assignedRepId       String?        @db.ObjectId
  assignedRep         User?          @relation("AssignedRep", fields: [assignedRepId], references: [id])
  createdById         String         @db.ObjectId
  createdBy           User           @relation("CreatedBy", fields: [createdById], references: [id])
  status              LocationStatus @default(ASSIGNED)
  contactModes        ContactMode[]
  contactEmail        String?
  contactPhone        String?
  reachedOutDate      DateTime?
  notes               String?
  normalizedEventName String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  activities          Activity[]
  notifications       Notification[]

  @@index([normalizedEventName])
  @@index([status])
  @@index([assignedRepId])
  @@index([cityId])
}

model Activity {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  userId      String       @db.ObjectId
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ActivityType
  locationId  String?      @db.ObjectId
  location    Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  description String
  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  userId     String           @db.ObjectId
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  message    String
  read       Boolean          @default(false)
  locationId String?          @db.ObjectId
  location   Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  cityId     String?          @db.ObjectId
  city       City?            @relation(fields: [cityId], references: [id], onDelete: SetNull)
  createdAt  DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}
